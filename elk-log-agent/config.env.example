# Elasticsearch / ELK endpoint configuration
# Copy this file to config.env and fill in your values.

# Elasticsearch base URL (required)
ELK_ENDPOINT="https://your-elasticsearch-host:9200"

# Authentication (choose one method)
# Method 1: Basic auth
ELK_USERNAME=""
ELK_PASSWORD=""

# Method 2: API key (base64-encoded id:api_key)
ELK_API_KEY=""

# Method 3: Bearer token
ELK_BEARER_TOKEN=""

# Index pattern to search (default: filebeat-*)
ELK_INDEX="filebeat-*"

# Time range for log retrieval (default: 1h)
# Supported: 15m, 30m, 1h, 6h, 12h, 24h, 7d
ELK_TIME_RANGE="1h"

# Maximum number of log entries to retrieve (default: 500)
ELK_MAX_RESULTS=500

# Log level filter (default: error). Options: error, warn, info, debug, all
ELK_LOG_LEVEL="error"

# Custom query filter (optional, Lucene syntax)
# Example: "service.name:payment-api AND http.response.status_code:500"
ELK_CUSTOM_QUERY=""

# TLS verification (set to "false" to skip, e.g. for self-signed certs)
ELK_TLS_VERIFY="true"

# Output directory for reports
ELK_REPORT_DIR="./reports"
